{
  "name": "mathathlone",
  "version": "0.1.0",
  "description": "Global math competition platform - Content × Time × Accuracy",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
