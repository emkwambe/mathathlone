# ============================================
# MATHATHLONE ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in values
# ============================================

# Supabase Configuration
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MathAthlone

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_ENABLE_FOCUS_DETECTION=true

# Cloudflare HeatRoom Worker (real-time competition transport)
# NEXT_PUBLIC_HEAT_WORKER_URL is the public URL of your deployed Cloudflare Worker.
# After running `wrangler deploy` in workers/heat-room/, Wrangler will print this URL.
# Example: https://mathathlone-heat-room.your-subdomain.workers.dev
NEXT_PUBLIC_HEAT_WORKER_URL=https://mathathlone-heat-room.your-subdomain.workers.dev

# Server-side Worker URL (can be the same value as above)
HEAT_WORKER_URL=https://mathathlone-heat-room.your-subdomain.workers.dev

# Shared secret between Next.js and the Cloudflare Worker.
# Generate with: openssl rand -hex 32
# Then set in Cloudflare via: cd workers/heat-room && wrangler secret put HEAT_ROOM_SECRET
HEAT_ROOM_SECRET=your-heat-room-secret-here

# Development Only
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-admin-operations
